# SecuritySnares (Bearer API key from dashboard)
SECURITYSNARES_BASE_URL=https://api.securitysnares.com
SECURITYSNARES_API_KEY=
# Set true for MSSP keys: uses GET /mssp/alerts?minutes=N
SECURITYSNARES_USE_MSSP=false
SECURITYSNARES_MSSP_MINUTES=15
SECURITYSNARES_POLL_SECONDS=60

# Heuristic: severity in ai_analysis JSON OR keyword in summary
RANSOMWARE_MIN_SEVERITY=70
RANSOMWARE_KEYWORD=ransomware

# BeyondTrust Password Safe Public API
# Example: https://your-bi-host/BeyondTrust/api/public/v3
BEYONDTRUST_BASE_URL=https://the-server/BeyondTrust/api/public/v3
BEYONDTRUST_API_KEY=
BEYONDTRUST_RUNAS=DOMAIN\\svc_api
# Only if your API registration requires RunAs password factor:
BEYONDTRUST_PASSWORD=
BEYONDTRUST_VERIFY_TLS=true
CREDENTIAL_CHANGE_QUEUE=true
CREDENTIAL_CHANGE_UPDATE_SYSTEM=true
# Optional: try systemName = host + "." + domain before hostname-only lookup (overridable via --company-domain)
COMPANY_DOMAIN=

# SMTP for incident emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
ADMIN_EMAIL_TO=security@example.com,ir@example.com

# Local SQLite idempotency store
STATE_DB_PATH=./data/automation_state.sqlite3

HTTP_TIMEOUT_SECONDS=30
MAX_RETRIES=5
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_COOLDOWN_SECONDS=120

LOG_LEVEL=INFO
